# AFAC2026 赛题四 环境变量模板
# 复制为 .env 后填入真实值(.env 已被 .gitignore 忽略,不会入库):
#   cp .env.example .env

# ---- 必填:模型平台(阿里云 DashScope / OpenAI 兼容接口)----
# API Key(优先读 DASHSCOPE_API_KEY,兼容 ARK_API_KEY)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OpenAI 兼容 base_url(替换为你的租户 endpoint)
OPENAI_BASE_URL=https://<your-endpoint>.maas.aliyuncs.com/compatible-mode/v1
# 主对话模型
MODEL_NAME=qwen3.6-plus

# ---- 可选:检索精排(qwen3-rerank)----
# rerank 端点(留空则退化为纯 BM25 + 本地重排)
RERANK_URL=https://<your-endpoint>.maas.aliyuncs.com/compatible-api/v1/reranks
RERANK_MODEL=qwen3-rerank

# ---- 可选:向量检索(留空则不启用 embedding)----
EMBEDDING_MODEL=

# ---- 可选:全局节流(秒/次)。不限流平台设 0;易 429 的平台设 16 左右 ----
MIN_CALL_INTERVAL=0
